{
  "name": "shop-api",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "setup": "bash ./setup.sh",
    "setup:win": "setup.bat",
    "dev": "nodemon --exec ts-node src/index.ts",
    "test": "RATE_LIMIT_MAX=10000 jest --verbose --setupFiles dotenv/config",
    "test:staged": "jest --findRelatedTests --passWithNoTests",
    "seed": "ts-node src/seeds/index.ts",
    "migrate": "knex migrate:latest",
    "migrate:make": "knex migrate:make",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:status": "knex migrate:status",
    "deploy:staging": "bash ./scripts/deploy-staging.sh",
    "deploy:production": "bash ./scripts/deploy-production.sh"
  },
  "type": "commonjs",
  "dependencies": {
    "@types/nodemailer": "^7.0.11",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.0.0",
    "express-rate-limit": "^8.2.1",
    "joi": "^17.13.0",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2",
    "nodemailer": "^8.0.1",
    "pg": "^8.11.0",
    "stripe": "^20.4.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "npm run test:staged --silent --"
    ]
  }
}
