# Database Configuration (Use 'localhost' if running backend natively, or 'db' if via full Docker compose)
DB_USER=user
DB_PASSWORD=password
DB_NAME=shop_db
DB_HOST=localhost
DB_PORT=5432

# Security & App
PORT=3000
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=24h
RATE_LIMIT_MAX=100

# Stripe Sandbox Settings (Retrieve from your Stripe Dashboard)
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret

DATABASE_URL=postgres://user:password@localhost:5432/shop_db
